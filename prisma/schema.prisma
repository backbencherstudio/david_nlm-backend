generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  ADMIN
  CUSTOMER
  VENDOR
  EVENT_PLANNER
  PROVIDER
  EDITOR
  CLIENT
}

enum ADMIN_APPROVE_STATUS {
  PENDING
  APPROVED
  NOT_APPLICABLE
  SUSPENDED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  PENDING
}

enum WorkingType {
  DAY
  HOUR
}

enum OperatedBy {
  REMOTE
  ON_SITE
  HYBRID
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  FAILED
}

enum SubscriptionBillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}


model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

model User {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?
  status     Int?      @default(1) @db.SmallInt

  first_name   String? @db.VarChar(255)
  last_name    String? @db.VarChar(255)
  name         String? @db.VarChar(255)
  avatar       String?
  location     String? @db.VarChar(255)
  phone_number String?
  email        String? @unique
  password     String? @db.VarChar(255)
  birthday     String?

  about_me String?
  address  String?
  type     UserType? @default(CUSTOMER)
  language String?   @db.VarChar(100)

  billing_id        String?
  stripe_connect_id String?
  balance           Decimal?  @default(0.0) @db.Decimal(10, 2)
  email_verified_at DateTime?

  bio           String?   @db.Text
  domain        String?   @unique
  username      String?   @unique
  country       String?
  state         String?
  city          String?
  zip_code      String?
  gender        String?
  date_of_birth DateTime? @db.Date
  approved_at   DateTime?
  availability  String?

  is_two_factor_enabled Int?      @default(0)
  two_factor_secret     String?
  accounts              Account[]

  vendorProfile VendorProfile? @relation("UserToVendorProfile")
  participants Participant[] @relation("participantUser")
  sentMessages Message[]     @relation("messageSender")
  businesses Business[] @relation("BusinessToUser")
  receivedNotifications Notification[] @relation("notificationReceiver")
  sentNotifications     Notification[] @relation("notificationSender")
  bookings              Booking[] @relation("BookingToUser")
  user_payment_methods UserPaymentMethod[]
  ucodes               Ucode[]
  role_users           RoleUser[]
  payment_transactions PaymentTransaction[]

  @@map("users")
}

model VendorProfile {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String @unique
  user    User   @relation("UserToVendorProfile", fields: [user_id], references: [id], onDelete: Cascade)

  subscription_active Boolean              @default(false)
  
  license_photo       String[]
  license_status      ADMIN_APPROVE_STATUS @default(PENDING)
  approved_at         DateTime?
  business_name           String?                  @db.VarChar(255)
  about_me                String?                  @db.Text
  address                 String?
  vendorSubscriptionPlans VendorSubscriptionPlan[]

  @@map("vendor_profiles")
}

model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token       String?
  email       String?
  expired_at  DateTime?
  verified_at DateTime?

  @@map("ucodes")
}


model Subscriptionlist {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  name String

  billing_cycle           SubscriptionBillingCycle?
  status                  SubscriptionStatus?
  vendorSubscriptionPlans VendorSubscriptionPlan[]

  @@map("subscriptions")
}

model VendorSubscriptionPlan {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  vendor_id String
  vendor    VendorProfile @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  subscription_id String
  subscription    Subscriptionlist @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  start_date DateTime?
  end_date   DateTime?

  payment_status SubscriptionPaymentStatus?

  @@map("vendor_subscriptions")
}

enum BusinessOperatedBy {
  HOME_BASED
  LOCATION_BASED
  MOBILE_BASED
  ONSITE_BASED
}

model Business {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  business_name        String? @db.VarChar(255)
  business_cover_photo String? @db.VarChar(255)
  business_description String? @db.VarChar(255)
  business_note        String? @db.Text

  category_id     String?
  category        ServiceCategory?    @relation("BusinessToCategory", fields: [category_id], references: [id])
  sub_category_id String?
  sub_category    ServiceSubCategory? @relation("BusinessToSubCategory", fields: [sub_category_id], references: [id])
  user_id         String
  owner            User @relation("BusinessToUser",fields: [user_id], references: [id], onDelete: Cascade)  

  OPERATED_BY BusinessOperatedBy?

  specialties  String? @db.VarChar(255)
  service_area String? @db.VarChar(255)

  portfolio_files String[] @db.Text

  packages Package[] @relation("BusinessToPackage")
  days     Day[]     @relation("BusinessToDay")
  bookings Booking[] @relation("BookingToBusiness")

  @@map("businesses")
}

model Package {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  package_name        String? @db.VarChar(255)
  package_description String? @db.Text
  package_image       String? @db.VarChar(255)

  side_choices  String?  @db.Text
  notes         String?  @db.Text
  service_price Decimal? @default(0.0) @db.Decimal(10, 2)

  business_id String
  business    Business @relation("BusinessToPackage", fields: [business_id], references: [id], onDelete: Cascade)
  bookings Booking[] @relation("BookingToService")

  @@map("packages")
}

model Day {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  day_name String? @db.VarChar(50)

  start_time String? @db.VarChar(10)
  end_time   String? @db.VarChar(10)

  intra_service_interval_hours   Int? @default(0)
  intra_service_interval_minutes Int? @default(0)

  business_id String
  business    Business @relation("BusinessToDay", fields: [business_id], references: [id], onDelete: Cascade)

  @@map("days")
}

 enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  }

  enum PaymentStatus {
    PENDING
    PAID
    FAILED
    REFUNDED
  }


 model Booking {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  booking_date DateTime?
  booking_start_time String? @db.VarChar(10)
  booking_end_time   String? @db.VarChar(10)
  booking_duration String? @db.Text

  status       BookingStatus?
  location     String? @db.VarChar(255)
  total_price  Decimal? @default(0.0) @db.Decimal(10, 2)

  payment_status PaymentStatus?
  
  user_id     String
  user        User     @relation("BookingToUser", fields: [user_id], references: [id], onDelete: Cascade)

  vendor_id String
  vendor    Business @relation("BookingToBusiness", fields: [vendor_id], references: [id], onDelete: Cascade)

  service_id String
  service    Package  @relation("BookingToService", fields: [service_id], references: [id], onDelete: Cascade)

 }


model Service {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  status     Int?     @default(1) @db.SmallInt

  name         String      @db.VarChar(255)
  operated_by  OperatedBy
  working_type WorkingType
  commission   Decimal     @default(0.0) @db.Decimal(5, 2)

  category_id String
  category    ServiceCategory @relation("ServiceCategoryRelation", fields: [category_id], references: [id])

  sub_categories ServiceToSubCategory[] @relation("ServiceWithManyToMany")
  @@map("services")
}

model ServiceCategory {
  id         String   @id @default(cuid())
  name       String   @unique @db.VarChar(255)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  services       Service[]            @relation("ServiceCategoryRelation")
  sub_categories ServiceSubCategory[] @relation("ServiceCategoryToSubCategory")
  businesses Business[] @relation("BusinessToCategory")

  @@map("service_categories")
}

model ServiceSubCategory {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name String @db.VarChar(255)
  category_id String
  category    ServiceCategory @relation("ServiceCategoryToSubCategory", fields: [category_id], references: [id], onDelete: Cascade)

  services ServiceToSubCategory[] @relation("Subcatagoryto-ServiceToSubCategory")
  businesses Business[] @relation("BusinessToSubCategory")

  @@unique([name, category_id])
  @@map("service_sub_categories")
}

model ServiceToSubCategory {
  service_id      String
  sub_category_id String

  service      Service            @relation("ServiceWithManyToMany", fields: [service_id], references: [id], onDelete: Cascade)
  sub_category ServiceSubCategory @relation("Subcatagoryto-ServiceToSubCategory", fields: [sub_category_id], references: [id], onDelete: Cascade)

  @@id([service_id, sub_category_id])
  @@map("service_to_sub_categories")
}


model Conversation {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  participants Participant[]
}

model Participant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("participantUser", fields: [userId], references: [id], onDelete: Cascade)

  role     String?  @default("participant")
  joinedAt DateTime @default(now())

  lastReadAt DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id        String   @id @default(cuid())
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status MessageStatus @default(PENDING)

  senderId String
  sender   User   @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  attachments String[] @db.Text
}

model NotificationEvent {
  id            String         @id @default(uuid())
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  deleted_at    DateTime?
  status        Int?           @default(1) @db.SmallInt
  type          String?
  text          String?
  notifications Notification[]
}

model Notification {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  read_at    DateTime?
  status     Int?      @default(1) @db.SmallInt

  sender_id String?
  sender    User?   @relation("notificationSender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("notificationReceiver", fields: [receiver_id], references: [id])

  notification_event_id String?
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])

  entity_id String?
}

model Role {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  title  String?
  name   String?

  permission_roles PermissionRole[]
  role_users       RoleUser[]
  permissions      Permission[]     @relation("PermissionToRole")

  @@map("roles")
}

model Permission {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  title      String?
  action     String?
  subject    String?
  conditions String?
  fields     String?

  permission_roles PermissionRole[]
  roles            Role[]           @relation("PermissionToRole")

  @@map("permissions")
}

model PermissionRole {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_roles")
}

model RoleUser {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([role_id, user_id])
  @@map("role_users")
}


model UserPaymentMethod {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  payment_method_id String?
  checkout_id       String?

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  store_id String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  order_id         String?
  type             String?  @default("order")
  withdraw_via     String?  @default("wallet")
  provider         String?
  reference_number String?
  status           String?  @default("pending")
  raw_status       String?
  amount           Decimal?
  currency         String?
  paid_amount      Decimal?
  paid_currency    String?

  @@map("payment_transactions")
}

model Faq {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  question   String?
  answer     String?

  @@map("faqs")
}

model Contact {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  first_name   String?
  last_name    String?
  email        String?
  phone_number String?
  message      String?

  @@map("contacts")
}

